DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/memoryrag
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Get a free API key at https://www.pinecone.io (Starter/free plan is enough for this project)
PINECONE_API_KEY=your-pinecone-api-key-here

# LLM provider for the RAG chat (Phase 4). Supported: groq | openrouter
#   Groq (free, fast):   https://console.groq.com/keys
#   OpenRouter:          https://openrouter.ai/keys
# LLM_MODEL is optional — leave unset to use a sensible default per provider
# (groq -> llama-3.3-70b-versatile, openrouter -> meta-llama/llama-3.3-70b-instruct).
LLM_PROVIDER=groq
LLM_API_KEY=your-llm-api-key-here
# LLM_MODEL=llama-3.3-70b-versatile

# Phase 7 — prompt versioning + context engineering
# Which intent-classifier prompt version to use (see backend/prompts/).
CLASSIFIER_PROMPT_VERSION=v2
# Total token budget for the variable parts of the chat prompt
# (split across system prompt / conversation history / retrieved context).
CONTEXT_TOKEN_BUDGET=1200
